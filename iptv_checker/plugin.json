{
  "name": "IPTV Checker",
  "version": "0.6.0c",
  "description": "A Dispatcharr Plugin that goes through a playlist to check IPTV channels",
  "author": "community",
  "help_url": "https://github.com/PiratesIRC/Dispatcharr-IPTV-Checker-Plugin",
  "fields": [
    {"id": "group_names", "label": "Group(s) to Check", "type": "string", "default": ""},
    {"id": "check_alternative_streams", "label": "Check Alternative Streams", "type": "boolean", "default": true},
    {"id": "timeout", "label": "Connection Timeout (seconds)", "type": "number", "default": 10},
    {"id": "probe_timeout", "label": "Probe Timeout (seconds)", "type": "number", "default": 20},
    {"id": "dead_connection_retries", "label": "Dead Connection Retries", "type": "number", "default": 3},
    {"id": "dead_rename_format", "label": "Dead Channel Rename Format", "type": "string", "default": "{name} [DEAD]"},
    {"id": "move_to_group_name", "label": "Move Dead Channels to Group", "type": "string", "default": "Graveyard"},
    {"id": "low_framerate_rename_format", "label": "Low Framerate Rename Format", "type": "string", "default": "{name} [Slow]"},
    {"id": "move_low_framerate_group", "label": "Move Low Framerate Channels to Group", "type": "string", "default": "Slow"},
    {"id": "video_format_suffixes", "label": "Add Video Format Suffixes", "type": "string", "default": "UHD, FHD, HD, SD, Unknown"},
    {"id": "enable_parallel_checking", "label": "Enable Parallel Stream Checking", "type": "boolean", "default": true},
    {"id": "parallel_workers", "label": "Number of Parallel Workers", "type": "number", "default": 2},
    {"id": "ffprobe_flags", "label": "FFprobe Analysis Flags", "type": "string", "default": "-show_streams,-show_frames,-show_packets,-loglevel error"},
    {"id": "ffprobe_analysis_duration", "label": "FFprobe Analysis Duration (seconds)", "type": "number", "default": 5},
    {"id": "ffprobe_path", "label": "FFprobe Path", "type": "string", "default": "/usr/local/bin/ffprobe"},
    {"id": "scheduled_times", "label": "Scheduled Check Times (Cron Format)", "type": "string", "default": ""},
    {"id": "scheduler_timezone", "label": "Scheduler Timezone", "type": "select", "default": "America/Chicago"},
    {"id": "scheduler_export_csv", "label": "Export CSV for Scheduled Checks", "type": "boolean", "default": false},
    {"id": "scheduler_rename_dead_channels", "label": "Rename Dead Channels After Scheduled Checks", "type": "boolean", "default": false},
    {"id": "scheduler_rename_low_framerate_channels", "label": "Rename Low Framerate Channels After Scheduled Checks", "type": "boolean", "default": false},
    {"id": "scheduler_add_video_format_suffix", "label": "Add Video Format Suffix After Scheduled Checks", "type": "boolean", "default": false},
    {"id": "scheduler_move_dead_channels", "label": "Move Dead Channels After Scheduled Checks", "type": "boolean", "default": false},
    {"id": "scheduler_move_low_framerate_channels", "label": "Move Low Framerate Channels After Scheduled Checks", "type": "boolean", "default": false}
  ],
  "actions": [
    {"id": "validate_settings", "label": "Validate Settings", "description": "Validate all plugin settings"},
    {"id": "update_schedule", "label": "Update Schedule", "description": "Apply current schedule settings"},
    {"id": "check_scheduler_status", "label": "Check Scheduler Status", "description": "Display scheduler status"},
    {"id": "load_groups", "label": "Load Group(s)", "description": "Load channels from specified groups"},
    {"id": "check_streams", "label": "Start Stream Check", "description": "Start checking stream status"},
    {"id": "view_progress", "label": "View Check Progress", "description": "View progress of running check"},
    {"id": "cancel_check", "label": "Cancel Stream Check", "description": "Cancel running stream check"},
    {"id": "view_results", "label": "View Last Results", "description": "View last check summary"},
    {"id": "rename_channels", "label": "Rename Dead Channels", "description": "Rename dead channels"},
    {"id": "move_dead_channels", "label": "Move Dead Channels to Group", "description": "Move dead channels"},
    {"id": "rename_low_framerate_channels", "label": "Rename Low Framerate Channels", "description": "Rename low FPS channels"},
    {"id": "move_low_framerate_channels", "label": "Move Low Framerate Channels", "description": "Move low FPS channels"},
    {"id": "add_video_format_suffix", "label": "Add Video Format Suffix", "description": "Add format suffix to channels"},
    {"id": "view_table", "label": "View Results Table", "description": "Display results table"},
    {"id": "export_results", "label": "Export Results to CSV", "description": "Export results to CSV"},
    {"id": "cleanup_orphaned_tasks", "label": "Cleanup Orphaned Tasks", "description": "Remove orphaned Celery tasks"},
    {"id": "clear_csv_exports", "label": "Clear CSV Exports", "description": "Delete all CSV exports"}
  ]
}
